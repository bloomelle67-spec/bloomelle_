:root {
  color-scheme: light;
  --bloom-bg: #f6efe7;
  --bloom-bg-strong: #fff9f4;
  --bloom-surface: rgba(255, 255, 255, 0.78);
  --bloom-surface-strong: rgba(255, 255, 255, 0.92);
  --bloom-text: #17202b;
  --bloom-muted: #5f6977;
  --bloom-accent: #bf6155;
  --bloom-accent-soft: #e8a58f;
  --bloom-sage: #9fb09b;
  --bloom-border: rgba(191, 97, 85, 0.16);
  --bloom-shadow: 0 22px 70px rgba(17, 24, 39, 0.12);
  --bloom-shadow-strong: 0 28px 80px rgba(17, 24, 39, 0.18);
}

html {
  scroll-behavior: smooth;
}

* {
  box-sizing: border-box;
}



body {
  font-family: "Plus Jakarta Sans", sans-serif;
  color: var(--bloom-text);
  background:
    radial-gradient(circle at top left, rgba(191, 97, 85, 0.16), transparent 28%),
    radial-gradient(circle at 82% 18%, rgba(159, 176, 155, 0.16), transparent 25%),
    radial-gradient(circle at bottom right, rgba(232, 165, 143, 0.16), transparent 30%),
    linear-gradient(180deg, var(--bloom-bg-strong), var(--bloom-bg));
  min-height: 100vh;
  overflow-x: hidden;
  letter-spacing: -0.01em;
  text-rendering: optimizeLegibility;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

